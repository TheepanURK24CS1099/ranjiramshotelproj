NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=3022
WEB_ORIGIN=http://localhost:3020
LOG_LEVEL=info
TRUST_PROXY=false
DATABASE_URL=postgresql://127.0.0.1:5432/hotel_management
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
SESSION_COOKIE_NAME=hotel_session
SESSION_DURATION_MS=86400000
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION_MS=900000
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=100
# Biometric devices are offline after five minutes without contact.
DEVICE_OFFLINE_THRESHOLD_MS=300000
DEVICE_STATUS_CHECK_INTERVAL_MS=60000
ADMS_BODY_LIMIT=64kb
# Offset used when an MB160 sends a timestamp without a timezone.
ADMS_TIMEZONE_OFFSET=+05:30
