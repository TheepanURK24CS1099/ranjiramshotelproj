{
  "name": "@hotel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.3.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "^24.0.0",
    "@types/supertest": "7.2.1",
    "eslint": "^9.39.5",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
