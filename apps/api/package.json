{
  "name": "@hotel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:check": "tsx src/scripts/check-database.ts",
    "db:migrate": "tsx src/scripts/migrate.ts up",
    "db:migrate:status": "tsx src/scripts/migrate.ts status",
    "db:migrate:down": "tsx src/scripts/migrate.ts down",
    "auth:create-admin": "tsx src/scripts/auth-create-admin.ts"
  },
  "dependencies": {
    "argon2": "0.45.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.6.0",
    "helmet": "8.3.0",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "^24.0.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.1",
    "eslint": "^9.39.5",
    "node-pg-migrate": "9.0.0",
    "pino-pretty": "13.1.3",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
