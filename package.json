{
  "name": "ranjirams-hotel-project",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "dev:web": "pnpm --filter @hotel/web dev",
    "dev:api": "pnpm --filter @hotel/api dev",
    "build:web": "pnpm --filter @hotel/web build",
    "build:api": "pnpm --filter @hotel/api build",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:api": "pnpm --filter @hotel/api test",
    "db:check": "pnpm --filter @hotel/api db:check",
    "db:migrate": "pnpm --filter @hotel/api run db:migrate",
    "db:migrate:status": "pnpm --filter @hotel/api run db:migrate:status",
    "auth:create-admin": "pnpm --filter @hotel/api run auth:create-admin"
  }
}
